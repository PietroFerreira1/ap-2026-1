import java.util.Scanner;

public class IdadeMenor_e_Maior {
    public static void main(String[] args) {
        
        Scanner scanner = new Scanner(System.in);
        
        Sistem.out.print("Qual a sua idade?: ");
        int idade = scanner.nextInt();
        
        if (idade >= 18) {
            Sistem.out.print("Você é maior de idade");
        }
        
        elif (idade >= 60) {
            Sistem.out.print("Você é idoso");
        }
        
        else {
            Sistem.out.print("Você é menor de idade");
        }
        
    }
}
